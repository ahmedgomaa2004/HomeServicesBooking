@model ServiceFormViewModel

@{
    ViewData["Title"] = "إضافة خدمة";
}

<h1 class="h3 mb-4">إضافة خدمة جديدة</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card admin-card">
            <div class="card-body">
                <form asp-area="Admin" asp-controller="Services" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">اسم الخدمة</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">وصف الخدمة</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">إضافة</button>
                        <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Services" asp-action="Index">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
