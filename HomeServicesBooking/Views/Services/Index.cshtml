@model List<ServiceCardViewModel>

@{
    ViewData["Title"] = "الخدمات";
}

<div class="page-heading">
    <h1>الخدمات</h1>
    <p class="text-muted">اختر الخدمة التي تحتاجها وابدأ طلب الحجز مباشرة.</p>
</div>

@if (Model.Any())
{
    <div class="row g-4">
        @foreach (var service in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card service-card h-100">
                    <div class="card-body d-flex flex-column">
                        <h2 class="h5 card-title">@service.Name</h2>
                        <p class="card-text text-muted flex-grow-1">@service.Description</p>
                        <div class="d-flex gap-2">
                            <a class="btn btn-outline-secondary" asp-controller="Services" asp-action="Details" asp-route-id="@service.Id">عرض التفاصيل</a>
                            <a class="btn btn-primary" asp-controller="Orders" asp-action="Create" asp-route-serviceId="@service.Id">احجز الخدمة</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">لا توجد خدمات متاحة حاليًا.</div>
}
