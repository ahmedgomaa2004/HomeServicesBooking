@model OrdersListViewModel

@{
    ViewData["Title"] = "إدارة الطلبات";

    string StatusClass(string s) => s switch
    {
        "Pending" => "badge-status badge-pending",
        "In Progress" => "badge-status badge-progress",
        "Done" => "badge-status badge-done",
        _ => "badge-status badge-inactive"
    };

    string StatusArabic(string s) => s switch
    {
        "Pending" => "جديد",
        "In Progress" => "قيد التنفيذ",
        "Done" => "مكتمل",
        _ => s
    };
}

<div class="page-header">
    <div>
        <h1>إدارة الطلبات</h1>
        <div class="page-subtitle">عرض، بحث، وتحديث حالة طلبات العملاء</div>
    </div>
</div>

<div class="card-pro mb-4">
    <div class="card-pro-body">
        <form method="get" asp-area="Admin" asp-controller="Orders" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label">
                    <i class="bi bi-search me-1 text-accent"></i>بحث
                </label>
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="اسم العميل أو رقم الموبايل..." />
            </div>
            <div class="col-md-4">
                <label class="form-label">
                    <i class="bi bi-funnel me-1 text-accent"></i>الحالة
                </label>
                <select name="status" class="form-select">
                    <option value="All" selected="@(Model.StatusFilter == "All" || string.IsNullOrEmpty(Model.StatusFilter))">جميع الحالات</option>
                    <option value="Pending" selected="@(Model.StatusFilter == "Pending")">جديد</option>
                    <option value="InProgress" selected="@(Model.StatusFilter == "InProgress")">قيد التنفيذ</option>
                    <option value="Done" selected="@(Model.StatusFilter == "Done")">مكتمل</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-funnel-fill"></i>
                    تطبيق الفلتر
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card-pro">
    <div class="card-pro-header">
        <h3><i class="bi bi-list-ul me-2 text-accent"></i>قائمة الطلبات</h3>
        @if (Model.Orders.Any())
        {
            <span class="text-muted" style="font-size: 0.88rem;">إجمالي: @Model.TotalPages صفحة</span>
        }
    </div>
    @if (Model.Orders.Any())
    {
        <div class="table-responsive">
            <table class="table-pro">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>اسم العميل</th>
                        <th>رقم الموبايل</th>
                        <th>الخدمة</th>
                        <th>تاريخ الحجز</th>
                        <th>الحالة</th>
                        <th class="text-center">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Orders.Count; i++)
                    {
                        var order = Model.Orders[i];
                        var rowNumber = (Model.CurrentPage - 1) * 10 + i + 1;
                        <tr>
                            <td><span class="text-muted">@rowNumber</span></td>
                            <td><strong>@order.CustomerName</strong></td>
                            <td><i class="bi bi-telephone text-muted me-1"></i>@order.Phone</td>
                            <td>@order.ServiceName</td>
                            <td><i class="bi bi-calendar3 text-muted me-1"></i>@order.OrderDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <span class="badge @StatusClass(order.Status)">@StatusArabic(order.Status)</span>
                            </td>
                            <td class="text-center">
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-area="Admin" asp-controller="Orders" asp-action="Details"
                                   asp-route-id="@order.Id">
                                    <i class="bi bi-eye"></i>
                                    تفاصيل
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="p-3" style="border-top: 1px solid var(--border-color);">
                <nav aria-label="صفحات الطلبات">
                    <ul class="pagination pagination-pro justify-content-center mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-area="Admin"
                               asp-controller="Orders"
                               asp-action="Index"
                               asp-route-search="@Model.SearchTerm"
                               asp-route-status="@Model.StatusFilter"
                               asp-route-page="@(Model.CurrentPage - 1)">
                                <i class="bi bi-chevron-right"></i>
                                السابق
                            </a>
                        </li>

                        <li class="page-item disabled">
                            <span class="page-link">صفحة @Model.CurrentPage من @Model.TotalPages</span>
                        </li>

                        <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-area="Admin"
                               asp-controller="Orders"
                               asp-action="Index"
                               asp-route-search="@Model.SearchTerm"
                               asp-route-status="@Model.StatusFilter"
                               asp-route-page="@(Model.CurrentPage + 1)">
                                التالي
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
    else
    {
        <div class="empty-state-pro" style="border: none; margin: 0;">
            <i class="bi bi-inbox empty-icon"></i>
            <h3>لا توجد طلبات مطابقة</h3>
            <p>جرّب تغيير معايير البحث أو الفلترة</p>
        </div>
    }
</div>
