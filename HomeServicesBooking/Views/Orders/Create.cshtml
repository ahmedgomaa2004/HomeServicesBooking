@model OrderFormViewModel

@{
    ViewData["Title"] = "حجز خدمة";
}

<div class="container py-4">
    <nav class="breadcrumb-pro">
        <a asp-controller="Home" asp-action="Index"><i class="bi bi-house-door"></i> الرئيسية</a>
        <span class="separator"><i class="bi bi-chevron-left"></i></span>
        <span>حجز خدمة</span>
    </nav>

    <div class="page-header">
        <div>
            <h1>حجز خدمة جديدة</h1>
            <div class="page-subtitle">املأ البيانات التالية لتسجيل طلبك، وسنتواصل معك في أقرب وقت</div>
        </div>
    </div>

    <form asp-controller="Orders" asp-action="Create" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card-pro mb-4">
                    <div class="card-pro-header">
                        <h3><i class="bi bi-person-circle me-2 text-accent"></i>بيانات العميل</h3>
                    </div>
                    <div class="card-pro-body">
                        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="CustomerName" class="form-label">الاسم الكامل</label>
                                <input asp-for="CustomerName" class="form-control" autocomplete="name" placeholder="أدخل اسمك" />
                                <span asp-validation-for="CustomerName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label">رقم الموبايل</label>
                                <input asp-for="Phone" class="form-control" inputmode="numeric" autocomplete="tel" placeholder="01xxxxxxxxx" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Address" class="form-label">العنوان</label>
                                <textarea asp-for="Address" class="form-control" rows="3" placeholder="المدينة، الحي، الشارع، رقم المبنى..."></textarea>
                                <span asp-validation-for="Address" class="text-danger"></span>
                                <div class="form-hint">اكتب عنوانك بتفصيل ليسهل على الفني الوصول</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-pro">
                    <div class="card-pro-header">
                        <h3><i class="bi bi-calendar-event me-2 text-accent"></i>تفاصيل الحجز</h3>
                    </div>
                    <div class="card-pro-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="ServiceId" class="form-label">نوع الخدمة</label>
                                <select asp-for="ServiceId" asp-items="Model.Services" class="form-select">
                                    <option value="">-- اختر الخدمة --</option>
                                </select>
                                <span asp-validation-for="ServiceId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="OrderDate" class="form-label">تاريخ الحجز</label>
                                <input asp-for="OrderDate" class="form-control" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="OrderDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card-pro" style="position: sticky; top: 90px;">
                    <div class="card-pro-header">
                        <h3><i class="bi bi-receipt me-2 text-accent"></i>ملخص الطلب</h3>
                    </div>
                    <div class="card-pro-body">
                        @if (!string.IsNullOrWhiteSpace(Model.ServiceName))
                        {
                            <div class="p-3 mb-3 rounded-pro" style="background: var(--bg-muted); border: 1px solid var(--border-color);">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                    <small class="text-muted">الخدمة المختارة</small>
                                </div>
                                <strong style="color: var(--color-primary);">@Model.ServiceName</strong>
                            </div>
                        }
                        else
                        {
                            <div class="p-3 mb-3 rounded-pro" style="background: var(--bg-muted); border: 1px dashed var(--border-color); text-align:center;">
                                <i class="bi bi-info-circle text-muted d-block mb-1" style="font-size: 1.2rem;"></i>
                                <small class="text-muted">اختر الخدمة من القائمة</small>
                            </div>
                        }

                        <div class="mb-4" style="font-size: 0.92rem;">
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-shield-check text-success mt-1"></i>
                                <span>طلبك آمن ومحفوظ</span>
                            </div>
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-telephone text-success mt-1"></i>
                                <span>سنتواصل معك خلال 24 ساعة</span>
                            </div>
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-patch-check text-success mt-1"></i>
                                <span>ضمان جودة الخدمة</span>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-send"></i>
                                إرسال الطلب
                            </button>
                            <a class="btn btn-outline-secondary" asp-controller="Services" asp-action="Index">
                                <i class="bi bi-x-lg"></i>
                                إلغاء
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
