@model OrderDetailsViewModel

@{
    ViewData["Title"] = $"تفاصيل الطلب #{Model.Id}";
}

<h1 class="h3 mb-4">تفاصيل الطلب #@Model.Id</h1>

<div class="row">
    <div class="col-lg-8">
        <div class="card admin-card mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">بيانات الطلب</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-4">اسم العميل</dt>
                    <dd class="col-sm-8">@Model.CustomerName</dd>

                    <dt class="col-sm-4">رقم الموبايل</dt>
                    <dd class="col-sm-8">@Model.Phone</dd>

                    <dt class="col-sm-4">العنوان</dt>
                    <dd class="col-sm-8">@Model.Address</dd>

                    <dt class="col-sm-4">الخدمة</dt>
                    <dd class="col-sm-8">@Model.ServiceName</dd>

                    <dt class="col-sm-4">تاريخ الحجز</dt>
                    <dd class="col-sm-8">@Model.OrderDate.ToString("yyyy-MM-dd")</dd>

                    <dt class="col-sm-4">الحالة</dt>
                    <dd class="col-sm-8">
                        <span class="badge @Model.StatusBadgeClass">@Model.Status</span>
                    </dd>

                    <dt class="col-sm-4">تاريخ الإنشاء</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

                    @if (Model.UpdatedAt.HasValue)
                    {
                        <dt class="col-sm-4">آخر تحديث</dt>
                        <dd class="col-sm-8">@Model.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")</dd>
                    }
                </dl>
            </div>
        </div>

        <div class="card admin-card">
            <div class="card-body">
                <h5 class="card-title mb-3">تغيير الحالة</h5>
                <form asp-area="Admin" asp-controller="Orders" asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row align-items-end">
                        <div class="col-sm-6">
                            <label class="form-label">الحالة الجديدة</label>
                            <select name="status" class="form-select">
                                @foreach (var option in Model.StatusOptions)
                                {
                                    <option value="@option.Value" selected="@(option.Value == Model.CurrentStatusCode)">@option.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <button type="submit" class="btn btn-primary">تحديث الحالة</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Orders" asp-action="Index">رجوع لإدارة الطلبات</a>
</div>
