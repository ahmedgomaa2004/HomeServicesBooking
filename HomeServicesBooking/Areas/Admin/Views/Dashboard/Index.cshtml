@model DashboardViewModel

@{
    ViewData["Title"] = "لوحة التحكم";
}

<h1 class="h3 mb-4">لوحة التحكم</h1>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card admin-stat-card">
            <div class="card-body text-center">
                <div class="stat-number">@Model.TotalOrdersCount</div>
                <div class="stat-label">إجمالي الطلبات</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card admin-stat-card">
            <div class="card-body text-center">
                <div class="stat-number text-warning">@Model.PendingOrdersCount</div>
                <div class="stat-label">طلبات جديدة</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card admin-stat-card">
            <div class="card-body text-center">
                <div class="stat-number text-success">@Model.DoneOrdersCount</div>
                <div class="stat-label">طلبات مكتملة</div>
            </div>
        </div>
    </div>
</div>

<h2 class="h5 mb-3">آخر 10 طلبات</h2>

@if (Model.LatestOrders.Any())
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>اسم العميل</th>
                    <th>الخدمة</th>
                    <th>التاريخ</th>
                    <th>الحالة</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.LatestOrders)
                {
                    <tr>
                        <td>@order.CustomerName</td>
                        <td>@order.ServiceName</td>
                        <td>@order.OrderDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <span class="badge @order.StatusBadgeClass">@order.Status</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="empty-state">لا توجد طلبات حاليًا</div>
}
