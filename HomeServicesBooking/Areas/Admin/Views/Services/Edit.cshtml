@model ServiceFormViewModel

@{
    ViewData["Title"] = "تعديل الخدمة";
}

<nav class="breadcrumb-pro">
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> لوحة التحكم</a>
    <span class="separator"><i class="bi bi-chevron-left"></i></span>
    <a asp-area="Admin" asp-controller="Services" asp-action="Index">الخدمات</a>
    <span class="separator"><i class="bi bi-chevron-left"></i></span>
    <span>تعديل</span>
</nav>

<div class="page-header">
    <div>
        <h1>تعديل الخدمة <span class="text-accent">#@Model.Id</span></h1>
        <div class="page-subtitle">قم بتعديل بيانات الخدمة وحفظ التغييرات</div>
    </div>
    <div>
        <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Services" asp-action="Index">
            <i class="bi bi-arrow-right"></i>
            رجوع للقائمة
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card-pro">
            <div class="card-pro-header">
                <h3><i class="bi bi-pencil-square me-2 text-accent"></i>بيانات الخدمة</h3>
            </div>
            <div class="card-pro-body">
                <form asp-area="Admin" asp-controller="Services" asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">
                            <i class="bi bi-tag me-1 text-accent"></i>اسم الخدمة
                        </label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                        <div class="form-hint">من 3 إلى 150 حرفًا</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label">
                            <i class="bi bi-card-text me-1 text-accent"></i>وصف الخدمة
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                        <div class="form-hint">من 10 إلى 1000 حرف</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2"></i>
                            حفظ التعديلات
                        </button>
                        <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Services" asp-action="Index">
                            <i class="bi bi-x-lg"></i>
                            إلغاء
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card-pro">
            <div class="card-pro-header">
                <h3><i class="bi bi-info-circle me-2 text-accent"></i>معلومات</h3>
            </div>
            <div class="card-pro-body" style="font-size: 0.92rem;">
                <div class="d-flex align-items-start gap-2 mb-3">
                    <i class="bi bi-info-circle-fill text-info mt-1"></i>
                    <span>تعديل الخدمة لا يؤثر على الطلبات القديمة المحفوظة</span>
                </div>
                <div class="d-flex align-items-start gap-2 mb-3">
                    <i class="bi bi-check-circle-fill text-success mt-1"></i>
                    <span>التعديلات تظهر فورًا للعملاء الجدد</span>
                </div>
                <div class="d-flex align-items-start gap-2">
                    <i class="bi bi-shield-check text-success mt-1"></i>
                    <span>حالة تفعيل الخدمة لا تتغير من هذه الصفحة</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
